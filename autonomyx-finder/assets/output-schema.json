{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "autonomyx-finder/output-schema.json",
  "title": "AutonomyX Finder Output",
  "type": "object",
  "required": ["search_mode", "schema_type", "summary", "sources"],
  "properties": {
    "name": { "type": "string" },
    "search_mode": { "type": "string" },
    "schema_type": { "type": "string" },
    "summary": { "type": "string" },
    "official_website": { "type": "string" },
    "schema_record": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "schema_type": { "type": "string" },
        "name": { "type": "string" },
        "identifiers": { "type": "array", "items": { "type": "object" } },
        "industries": { "type": "array", "items": { "type": "string" } },
        "topics": { "type": "array", "items": { "type": "string" } },
        "skills": { "type": "array", "items": { "type": "object" } },
        "profiles": { "type": "array", "items": { "type": "object" } },
        "relations": { "type": "array", "items": { "type": "object" } }
      },
      "additionalProperties": true
    },
    "action_record": {
      "type": "object",
      "properties": {
        "actor": { "type": "string" },
        "action_type": { "type": "string" },
        "object": { "type": "string" },
        "target": { "type": "string" },
        "time": { "type": "string" },
        "location": { "type": "string" },
        "journey_path": { "type": "array", "items": { "type": "string" } },
        "mode_of_transport": { "type": "string" },
        "source": { "type": "string" },
        "source_tier": { "type": "integer" },
        "trust_score": { "type": "number" },
        "confidence": { "type": "string" },
        "status": { "type": "string" }
      },
      "additionalProperties": true
    },
    "knowledge_graph": {
      "type": "object",
      "properties": {
        "nodes": { "type": "array", "items": { "type": "object" } },
        "edges": { "type": "array", "items": { "type": "object" } },
        "mermaid": { "type": "string" }
      },
      "additionalProperties": true
    },
    "resolution_result": {
      "type": "object",
      "properties": {
        "resolution": { "type": "string" },
        "confidence": { "type": "string" },
        "evidence": { "type": "array", "items": { "type": "string" } },
        "recommended_action": { "type": "string" },
        "source_of_information": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        },
        "trust_score": { "type": "number" }
      },
      "additionalProperties": true
    },
    "sort_filter_attributes": {
      "type": "object",
      "properties": {
        "relevancy": { "type": "number" },
        "recency": { "type": "number" },
        "contextuality": { "type": "number" },
        "source_tier": { "type": "integer" },
        "trust_score": { "type": "number" },
        "location": { "type": "string" },
        "distance": { "type": "number" },
        "event_time": { "type": "string" },
        "published_at": { "type": "string" }
      },
      "additionalProperties": true
    },
    "important_data_points": {
      "type": "object",
      "additionalProperties": true
    },
    "employment_life_signals": {
      "type": "array",
      "items": { "type": "object" }
    },
    "related_nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "node": { "type": "string" },
          "hop_distance": { "type": "integer" },
          "discovery_path": { "type": "array", "items": { "type": "string" } },
          "path_strength": { "type": "number" }
        },
        "additionalProperties": true
      }
    },
    "timeline": {
      "type": "array",
      "items": { "type": "object" }
    },
    "correlations": {
      "type": "array",
      "items": { "type": "object" }
    },
    "crawl_summary": {
      "type": "object",
      "additionalProperties": true
    },
    "trace": {
      "type": "object",
      "additionalProperties": true
    },
    "caveats": {
      "type": "array",
      "items": { "type": "string" }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["url"],
        "properties": {
          "url": { "type": "string" },
          "platform": { "type": "string" },
          "source_tier": { "type": "integer" },
          "trust_score": { "type": "number" },
          "published_at": { "type": "string" },
          "location": { "type": "string" },
          "verification_status": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
